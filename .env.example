# Copiar este archivo a .env y ajustar los valores.
# .env está en .gitignore — nunca versionar el archivo con credenciales reales.

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_USER=infiltrado
DB_PASSWORD=infiltrado_dev_password
DB_NAME=infiltrado
DB_HOST=localhost

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Mínimo 32 caracteres; cambiar en producción.
JWT_SECRET=cambia-este-secreto-en-produccion-minimo-32-caracteres-obligatorio
